<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:layoutDirection="rtl"
    android:background="@drawable/widget_bg">

    <TextView
        android:id="@+id/widget_prayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#2FDE9B"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_appts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="13sp"
        android:textColor="#C8D0DC"
        android:maxLines="2"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_water"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#C8D0DC" />

        <Button
            android:id="@+id/widget_water_add"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:text="+"
            android:textSize="18sp"
            android:textColor="#04271B"
            android:background="@drawable/widget_btn_bg" />
    </LinearLayout>
</LinearLayout>
