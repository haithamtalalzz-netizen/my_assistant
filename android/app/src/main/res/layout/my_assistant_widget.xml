<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:layoutDirection="rtl"
    android:background="@drawable/widget_bg">

    <!-- الصلاة القادمة (السطر البارز) -->
    <TextView
        android:id="@+id/widget_prayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#2FDE9B"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- عمودان: المهام | الفواتير -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="0dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المهام"
                android:textSize="11sp"
                android:textColor="#7C8AA0" />

            <TextView
                android:id="@+id/widget_tasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="13sp"
                android:textColor="#EAF0F7"
                android:maxLines="3"
                android:ellipsize="end" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginVertical="2dp"
            android:background="#243348" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الفواتير"
                android:textSize="11sp"
                android:textColor="#7C8AA0" />

            <TextView
                android:id="@+id/widget_bills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="13sp"
                android:textColor="#EAF0F7"
                android:maxLines="3"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- المواعيد -->
    <TextView
        android:id="@+id/widget_appts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="12sp"
        android:textColor="#C8D0DC"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- المياه + زر الإضافة -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_water"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#C8D0DC" />

        <Button
            android:id="@+id/widget_water_add"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:text="+"
            android:textSize="18sp"
            android:textColor="#04271B"
            android:background="@drawable/widget_btn_bg" />
    </LinearLayout>

    <!-- إجراءات سريعة: تسجيل وجبة / فتح المهام -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/widget_meal_add"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="🍽 وجبة"
            android:textSize="12sp"
            android:textColor="#04271B"
            android:background="@drawable/widget_btn_bg" />

        <Button
            android:id="@+id/widget_task_add"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="☑ المهام"
            android:textSize="12sp"
            android:textColor="#04271B"
            android:background="@drawable/widget_btn_bg" />
    </LinearLayout>
</LinearLayout>
